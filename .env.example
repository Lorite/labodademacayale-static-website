# Copy this file to .env for local development, and set the same variables
# in Coolify (Environment Variables) for production.
# The real .env file is git-ignored and must NEVER be committed.

# The password guests type to enter the site.
SITE_PASSWORD=change-me-to-a-shared-guest-password

# A long random string used to sign the session cookie.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Optional — port the server listens on (Coolify maps this automatically).
PORT=3000

# Optional — how many hours a login stays valid (default 720 = 30 days).
SESSION_HOURS=720

# Set to "production" on the server so the session cookie is HTTPS-only.
NODE_ENV=production

# ---- Wedding gift / bank details ----
# Injected into the page at request time (only visible to logged-in guests).
# Keep the REAL value out of git — set it only in your local .env and in Coolify.
GIFT_IBAN=ES00 0000 0000 0000 0000 0000
# Optional — shown under the IBAN (leave blank to hide the row):
GIFT_HOLDER=Maca y Ale
